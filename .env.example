# ╔══════════════════════════════════════════════════════════════════════╗
# ║  SRR-AGENTS — Environment Configuration                            ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── LLM Provider (required) ──────────────────────────────────────────
# OpenRouter: single key routes to Claude Sonnet + Kimi K2.5
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxx

# ── GitHub (required for Builder Agent) ──────────────────────────────
# Personal access token with repo scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxx
GITHUB_USERNAME=stevenrivadeneira

# ── Optional: Override default model ─────────────────────────────────
# OPENCLAW_MODEL=claude-sonnet-4-6

# ── Discord (for agent notifications) ────────────────────────────────
# Create a bot at: https://discord.com/developers/applications
# Enable "Message Content Intent" under Bot settings
DISCORD_BOT_TOKEN=your_bot_token_here

# ── Optional: Additional API keys for Scout/Intel agents ─────────────
# SERP_API_KEY=              # For job search enrichment
# HN_API_BASE=https://hacker-news.firebaseio.com/v0

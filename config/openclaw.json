{
  "env": {
    "OPENAI_API_KEY": "${OPENROUTER_API_KEY}",
    "OPENAI_BASE_URL": "https://openrouter.ai/api/v1"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4"
      },
      "workspace": "/home/node/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "subagents": {
        "maxConcurrent": 3,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5,
        "archiveAfterMinutes": 120,
        "model": "openrouter/moonshotai/kimi-k2.5",
        "thinking": "disabled",
        "runTimeoutSeconds": 1800
      }
    },
    "list": [
      {
        "id": "orchestrator",
        "default": true,
        "name": "SRR Orchestrator",
        "model": {
          "primary": "openrouter/anthropic/claude-sonnet-4"
        },
        "skills": [
          "orchestrator"
        ]
      },
      {
        "id": "builder",
        "name": "SRR Builder",
        "model": {
          "primary": "openrouter/anthropic/claude-sonnet-4"
        },
        "skills": [
          "builder"
        ]
      },
      {
        "id": "scout",
        "name": "SRR Scout",
        "model": {
          "primary": "openrouter/moonshotai/kimi-k2.5"
        },
        "skills": [
          "scout"
        ]
      },
      {
        "id": "intel",
        "name": "SRR Intel",
        "model": {
          "primary": "openrouter/moonshotai/kimi-k2.5"
        },
        "skills": [
          "intel"
        ]
      }
    ]
  },
  "tools": {
    "allow": [
      "exec",
      "read",
      "write",
      "edit",
      "browser"
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "daily",
      "atHour": 4
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "dm": {
        "enabled": true
      },
      "streaming": "off"
    }
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "975bba8381c250d9794e07fba0b1884f5421dcf2129aa2e0"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.1-beta.1",
    "lastTouchedAt": "2026-03-02T07:40:28.250Z"
  }
}
